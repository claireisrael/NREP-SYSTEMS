{
  "expo": {
    "name": "NREP SYSTEMS",
    "slug": "nrep-systems",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/nrep-logo.png",
    "scheme": "mobile",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "ug.nrep.systems"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/images/nrep-logo.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "ug.nrep.systems"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/nrep-logo.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/nrep-logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#FFFFFF"
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "extra": {
      "APPWRITE_ENDPOINT": "https://appwrite.nrep.ug/v1",
      "APPWRITE_PROJECT_ID": "66bcc8450005201fa1af",
      "APPWRITE_DATABASE_ID": "68fb5845001d32f31656",
      "router": {},
      "eas": {
        "projectId": "6697a014-2e8c-4319-affb-0345de49a173"
      }
    },
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "owner": "israel_claire"
  }
}
